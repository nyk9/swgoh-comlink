# SWGoH Advisor CLI - 環境変数設定ファイル
# このファイルをコピーして .env を作成し、実際の値を設定してください。
# $ cp .env.example .env

# -------------------------------------------------------
# Google Gemini API キー（デフォルトプロバイダー／テスト推奨）
# https://aistudio.google.com/apikey で無料取得できます
# -------------------------------------------------------
GOOGLE_GENERATIVE_AI_API_KEY=your_google_api_key_here

# -------------------------------------------------------
# Anthropic API キー（--provider anthropic 使用時）
# https://console.anthropic.com/ で取得してください
# -------------------------------------------------------
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# -------------------------------------------------------
# Comlink設定（省略可）
# デフォルト: http://localhost:5001
# -------------------------------------------------------
# COMLINK_URL=http://localhost:5001

# -------------------------------------------------------
# デバッグ設定（省略可）
# 1 に設定するとエラー時にスタックトレースを表示する
# -------------------------------------------------------
# DEBUG=0

DISCORD_TOKEN=

DISCORD_APPLICATION_ID=

DISCORD_GUILD_ID=
