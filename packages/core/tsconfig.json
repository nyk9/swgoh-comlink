{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "composite": true,
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": [
    "**/*.ts",
    "**/*.json",
    "!node_modules",
    "!dist"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
