{
  "_comment": "RotE (Rise of the Empire) TB ミッション情報 - 手動管理ファイル。スペシャルミッションと属性限定戦闘ミッションを統合管理する。",
  "_lastUpdated": "YYYY-MM-DD",
  "_schema": {
    "phases[].phase": "フェーズ番号（1〜6）",
    "phases[].zones[].zoneId": "ゾーンの識別子（任意の文字列）",
    "phases[].zones[].zoneName": "ゾーン名（例: Dark Side / Light Side / Neutral）",
    "phases[].zones[].missions[].missionId": "ミッションの識別子（任意の文字列）",
    "phases[].zones[].missions[].missionName": "ミッション名（例: Special Mission 1）",
    "phases[].zones[].missions[].missionType": "ミッション種別: 'special'（特別報酬あり）| 'combat_restricted'（属性限定戦闘ミッション、通常TP報酬のみ）。省略時は 'special' として扱う",
    "phases[].zones[].missions[].description": "ミッションの説明・備考",
    "phases[].zones[].missions[].squads[].squadId": "編成の識別子（同一ミッションに複数編成がある場合を考慮）",
    "phases[].zones[].missions[].squads[].squadName": "編成名（例: Squad A）",
    "phases[].zones[].missions[].squads[].requiredTags": "スクワッド全体の属性タグ制限（省略可）。例: ['Mandalorian'] → マンダロリアン属性のキャラのみ参加可",
    "phases[].zones[].missions[].squads[].units[].id": "ComlinkのユニットID（例: DARTHVADER）。isAny=true の場合は属性ラベル（例: 'Any Mandalorian'）",
    "phases[].zones[].missions[].squads[].units[].requiredRelicLevel": "必要レリックレベル（0=レリック不要、1〜9）",
    "phases[].zones[].missions[].squads[].units[].isLeader": "リーダー指定かどうか（true/false）",
    "phases[].zones[].missions[].squads[].units[].isAny": "任意枠かどうか（省略可）。true = 属性タグを満たす任意キャラでOK。false または省略 = id で指定した特定キャラが必須",
    "phases[].zones[].missions[].squads[].units[].note": "メモ（キャラの表示名・属性名など）"
  },
